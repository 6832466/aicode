{
  "name": "duanju-auto",
  "productName": "短剧素材采集工具",
  "version": "1.0.0",
  "author": "lxc",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "set ELECTRON_RUN_AS_NODE= && electron .",
    "start": "set ELECTRON_RUN_AS_NODE= && concurrently \"npm run dev\" \"npm run electron\"",
    "electron-build": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.duanju.auto",
    "copyright": "Copyright © 2025",
    "productName": "短剧素材采集工具",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "resource/**/*"
    ],
    "extraResources": [
      {
        "from": "backend-dist/",
        "to": "backend/"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "electron/**/*.exe"
    ],
    "win": {
      "icon": "resource/icon/app.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.16.1",
    "element-plus": "^2.14.0",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "concurrently": "^9.2.1",
    "electron": "^37.10.3",
    "electron-builder": "^26.8.1",
    "vite": "^7.3.3"
  }
}
